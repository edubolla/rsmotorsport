---
import LayoutSite from "../layouts/LayoutSite.astro"
import CTAWhatsApp from "../components/CTAWhatsApp.astro"

const servicos = [
  {
    titulo: "Revisão Premium",
    descricao: "Checklist completo com mais de 50 itens. Diagnóstico eletrônico, troca de óleo e fluidos, freios e suspensão.",
    href: "/lp/revisao",
    icone: "🔧",
  },
  {
    titulo: "Revisão Preventiva",
    descricao: "Manutenção programada para manter o carro em dia e evitar desgastes prematuros antes que virem problemas.",
    href: "/lp/revisao",
    icone: "📋",
  },
  {
    titulo: "Revisão Reparativa",
    descricao: "Diagnóstico preciso para identificar a causa raiz de qualquer sintoma — barulho, vibração, luz no painel.",
    href: "/lp/revisao",
    icone: "🔍",
  },
  {
    titulo: "Performance e Remap",
    descricao: "Reprogramação da ECU para liberar o potencial real do motor. Mais potência, melhor resposta, com segurança.",
    href: "/lp/performance",
    icone: "⚡",
  },
  {
    titulo: "Lavagem Detalhada",
    descricao: "Limpeza profissional interna e externa. Não é lavagem comum — é um processo completo de cuidado do veículo.",
    href: "/lp/lavagem",
    icone: "✨",
  },
]

const depoimentos = [
  { nome: "Ismael Rodrigues", texto: "Mecânica bem organizada, responsável mecânicos de extrema confiança.", veiculo: "Cliente verificado · Google" },
  { nome: "Eduardo Alves Dias", texto: "Oficina especializada, pessoal muito gente boa! Sempre te explicam tudo que será necessário fazer, sem forçar nenhum serviço, recomendo!", veiculo: "Cliente verificado · Google" },
  { nome: "Juliano França", texto: "Serviço de extrema qualidade. Profissionais super qualificados.", veiculo: "Cliente verificado · Google" },
  { nome: "Rogério Macieski", texto: "Extremamente profissionais e qualificados.", veiculo: "Cliente verificado · Google" },
]
---

<LayoutSite>

  <!-- NAV -->
  <nav class="fixed top-0 left-0 right-0 z-50 bg-[#0A0A0A]/95 backdrop-blur-sm border-b border-white/5">
    <div class="max-w-6xl mx-auto px-5 py-4 flex items-center justify-between">
      <img src="/logotipo/RS-2Logo.webp" alt="RS Motorsport" class="h-8 w-auto" />
      <a
        href={`https://wa.me/555135972593?text=${encodeURIComponent("Olá! Quero saber mais sobre os serviços da RS Motorsport.")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden md:inline-flex items-center gap-2 bg-[#E01010] hover:bg-[#B50D0D] text-white font-heading font-semibold uppercase tracking-wide text-sm px-5 py-2.5 rounded transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        WhatsApp
      </a>
    </div>
  </nav>

  <!-- 1. HERO -->
  <section id="hero" class="relative overflow-hidden min-h-screen flex items-center bg-[#0A0A0A] pt-16">
    <div class="absolute inset-0 bg-gradient-to-br from-[#E01010]/8 via-transparent to-[#141414]/80 pointer-events-none"></div>
    <!-- Linha diagonal decorativa -->
    <div class="absolute top-0 right-0 w-1/2 h-full bg-gradient-to-l from-[#141414] to-transparent pointer-events-none hidden md:block"></div>

    <div class="relative max-w-6xl mx-auto px-5 py-20 md:py-32 w-full">
      <div class="max-w-2xl">
        <p class="inline-block bg-[#E01010]/10 text-[#E01010] text-xs font-heading font-semibold uppercase tracking-widest px-3 py-1 rounded mb-6">
          Campo Bom/RS · Mais de 12 Anos de Experiência
        </p>
        <h1 class="font-heading text-5xl md:text-7xl font-bold leading-none mb-6 text-[#F5F5F5]">
          Sua Oficina<br />
          <span class="text-[#E01010]">Premium</span><br />
          no Vale do Sinos
        </h1>
        <p class="text-[#888888] text-xl mb-10 max-w-lg leading-relaxed">
          Revisão, performance e cuidado completo para carros nacionais e importados. Diagnóstico preciso, transparência total e resultado garantido.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <CTAWhatsApp
            mensagem="Olá! Quero saber mais sobre os serviços da RS Motorsport."
            texto="Agendar pelo WhatsApp"
            tamanho="lg"
          />
          <a
            href="#servicos"
            class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white/40 text-[#F5F5F5] font-heading font-semibold uppercase tracking-wide px-7 py-4 text-base rounded transition-all duration-200"
          >
            Ver Serviços
          </a>
        </div>
        <!-- Stats -->
        <div class="flex flex-wrap gap-8 mt-12">
          {[
            { numero: "12+", label: "Anos de Mercado" },
            { numero: "1.000+", label: "Clientes Atendidos" },
            { numero: "5★", label: "Avaliação Google" },
          ].map(({ numero, label }) => (
            <div>
              <p class="font-display text-3xl text-[#E01010]">{numero}</p>
              <p class="text-[#888888] text-sm">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 2. SERVIÇOS -->
  <section id="servicos" class="bg-[#141414] px-5 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-widest mb-3">O que fazemos</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#F5F5F5] mb-4">Serviços Disponíveis</h2>
        <p class="text-[#888888] max-w-md mx-auto">Cada serviço é realizado com os equipamentos certos e a equipe especializada que seu carro merece.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {servicos.map(({ titulo, descricao, href, icone }) => (
          <a
            href={href}
            class="group bg-[#1E1E1E] border border-white/5 hover:border-[#E01010]/30 rounded-xl p-6 transition-all duration-200 hover:bg-[#242424]"
          >
            <span class="text-3xl mb-4 block">{icone}</span>
            <h3 class="font-heading text-lg font-bold text-[#F5F5F5] mb-2 group-hover:text-[#E01010] transition-colors">{titulo}</h3>
            <p class="text-[#888888] text-sm leading-relaxed mb-4">{descricao}</p>
            <span class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-wider group-hover:gap-2 transition-all inline-flex items-center gap-1">
              Saiba mais →
            </span>
          </a>
        ))}
        <!-- Card importados -->
        <a
          href="/lp/importados"
          class="group bg-[#1E1E1E] border border-white/5 hover:border-[#E01010]/30 rounded-xl p-6 transition-all duration-200 hover:bg-[#242424]"
        >
          <span class="text-3xl mb-4 block">🏆</span>
          <h3 class="font-heading text-lg font-bold text-[#F5F5F5] mb-2 group-hover:text-[#E01010] transition-colors">Especialistas em Importados</h3>
          <p class="text-[#888888] text-sm leading-relaxed mb-4">Audi, BMW, Mercedes-Benz, Volvo e mais. Scanner original da marca, peças OEM e técnicos especializados.</p>
          <span class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-wider group-hover:gap-2 transition-all inline-flex items-center gap-1">
            Saiba mais →
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- 3. POR QUE ESCOLHER -->
  <section id="sobre" class="bg-[#0A0A0A] px-5 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-widest mb-3">Quem somos</p>
          <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#F5F5F5] mb-6">
            Mais de 12 anos cuidando do que importa para você
          </h2>
          <p class="text-[#888888] leading-relaxed mb-6">
            A RS Motorsport nasceu da paixão por carros e do compromisso com a qualidade. Ao longo de mais de 12 anos em Campo Bom, construímos uma reputação baseada em diagnóstico preciso, transparência e resultado real.
          </p>
          <p class="text-[#888888] leading-relaxed mb-8">
            Atendemos desde carros populares até importados de alta gama — com o mesmo padrão de cuidado, os mesmos equipamentos e a mesma equipe dedicada em cada serviço.
          </p>
          <CTAWhatsApp
            mensagem="Olá! Quero agendar um serviço na RS Motorsport."
            texto="Falar com a Equipe"
          />
        </div>
        <div class="grid grid-cols-2 gap-4">
          {[
            { icone: "🔌", titulo: "Diagnóstico Eletrônico", desc: "Equipamentos de última geração para cada marca" },
            { icone: "🧰", titulo: "Equipe Especializada", desc: "Mecânicos treinados em nacionais e importados" },
            { icone: "📋", titulo: "Laudo Detalhado", desc: "Relatório completo de cada serviço realizado" },
            { icone: "💬", titulo: "Transparência Total", desc: "Você aprova o orçamento antes de qualquer serviço" },
            { icone: "✅", titulo: "Garantia Real", desc: "Peças e mão de obra com garantia documentada" },
            { icone: "📅", titulo: "Agenda Rápida", desc: "Atendimento ágil via WhatsApp, sem burocracia" },
          ].map(({ icone, titulo, desc }) => (
            <div class="bg-[#141414] border border-white/5 rounded-lg p-4">
              <span class="text-xl mb-2 block">{icone}</span>
              <p class="font-heading font-semibold text-[#F5F5F5] text-sm mb-1">{titulo}</p>
              <p class="text-[#888888] text-xs leading-relaxed">{desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- 4. DEPOIMENTOS -->
  <section id="depoimentos" class="bg-[#141414] px-5 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-widest mb-3">Prova Social</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#F5F5F5] mb-4">O que nossos clientes dizem</h2>
        <p class="text-[#888888]">Mais de 12 anos construindo confiança em Campo Bom e região</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {depoimentos.map(({ nome, texto, veiculo }) => (
          <div class="bg-[#1E1E1E] border border-white/5 rounded-xl p-6">
            <div class="flex gap-1 mb-3">
              {Array(5).fill(0).map(() => <span class="text-[#E01010] text-sm">★</span>)}
            </div>
            <p class="text-[#F5F5F5]/80 leading-relaxed mb-5">"{texto}"</p>
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-full bg-[#E01010]/10 flex items-center justify-center text-[#E01010] font-heading font-bold text-sm shrink-0">
                {nome[0]}
              </div>
              <div>
                <p class="font-heading font-semibold text-[#F5F5F5] text-sm">{nome}</p>
                <p class="text-[#888888] text-xs">{veiculo}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. LOCALIZAÇÃO -->
  <section id="localizacao" class="bg-[#0A0A0A] px-5 py-16 md:py-24">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <p class="text-[#E01010] text-xs font-heading font-semibold uppercase tracking-widest mb-3">Como chegar</p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold text-[#F5F5F5] mb-4">Onde Estamos</h2>
      </div>
      <div class="grid md:grid-cols-2 gap-8 items-start">
        <div class="bg-[#141414] border border-white/5 rounded-xl overflow-hidden">
          <iframe
            src="https://maps.google.com/maps?q=-29.6728914,-51.0601064&hl=pt-BR&z=16&output=embed"
            width="100%"
            height="300"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização RS Motorsport"
          ></iframe>
        </div>
        <div class="space-y-5">
          <div class="bg-[#141414] border border-white/5 rounded-xl p-5 flex items-start gap-4">
            <span class="text-[#E01010] text-2xl shrink-0">📍</span>
            <div>
              <p class="font-heading font-semibold text-[#F5F5F5] mb-1">Endereço</p>
              <p class="text-[#888888] text-sm leading-relaxed">R. Emilio Pedro Goedtel, 75<br />Bairro Metzler — Campo Bom/RS<br />CEP 93717-145</p>
            </div>
          </div>
          <div class="bg-[#141414] border border-white/5 rounded-xl p-5 flex items-start gap-4">
            <span class="text-[#E01010] text-2xl shrink-0">🕐</span>
            <div>
              <p class="font-heading font-semibold text-[#F5F5F5] mb-1">Horário de Funcionamento</p>
              <p class="text-[#888888] text-sm">Segunda a Sexta — 08h às 18h</p>
            </div>
          </div>
          <div class="bg-[#141414] border border-white/5 rounded-xl p-5 flex items-start gap-4">
            <span class="text-[#E01010] text-2xl shrink-0">📱</span>
            <div>
              <p class="font-heading font-semibold text-[#F5F5F5] mb-2">Fale Conosco</p>
              <CTAWhatsApp
                mensagem="Olá! Quero saber mais sobre os serviços da RS Motorsport."
                texto="Abrir WhatsApp"
                tamanho="sm"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 6. CTA FINAL -->
  <section class="bg-[#E01010] px-5 py-16 md:py-24">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="font-heading text-3xl md:text-5xl font-bold text-white mb-4 leading-tight">
        Pronto para cuidar do seu carro?
      </h2>
      <p class="text-white/80 mb-8 text-lg leading-relaxed">
        Fale agora com nossa equipe via WhatsApp. Resposta rápida, sem burocracia.
      </p>
      <a
        href={`https://wa.me/555135972593?text=${encodeURIComponent("Olá! Quero saber mais sobre os serviços da RS Motorsport.")}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center gap-2.5 bg-white text-[#E01010] font-heading font-bold uppercase tracking-wide px-10 py-5 text-lg rounded transition-all duration-200 hover:bg-[#F5F5F5] active:scale-95 shadow-xl"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
        </svg>
        Falar no WhatsApp Agora
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-[#141414] border-t border-white/5 px-5 py-10">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 mb-8">
        <img src="/logotipo/RS-2Logo.webp" alt="RS Motorsport" class="h-8 w-auto" />
        <div class="flex items-center gap-5">
          <a
            href="https://www.instagram.com/rsmotorsportcb/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#888888] hover:text-[#F5F5F5] transition-colors text-sm font-heading"
          >
            Instagram
          </a>
          <a
            href="https://share.google/THHO7AOJNepz6EVvo"
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#888888] hover:text-[#F5F5F5] transition-colors text-sm font-heading"
          >
            Google Maps
          </a>
          <a
            href={`https://wa.me/555135972593?text=${encodeURIComponent("Olá! Quero saber mais sobre os serviços da RS Motorsport.")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[#888888] hover:text-[#F5F5F5] transition-colors text-sm font-heading"
          >
            WhatsApp
          </a>
        </div>
      </div>
      <div class="border-t border-white/5 pt-6 text-center">
        <p class="text-[#888888] text-xs">
          © {new Date().getFullYear()} RS Motorsport · R. Emilio Pedro Goedtel, 75 — Campo Bom/RS · Todos os direitos reservados
        </p>
      </div>
    </div>
  </footer>

</LayoutSite>
