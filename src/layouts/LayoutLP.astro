---
import "../styles/global.css"
import BotaoWhatsAppFlutuante from "../components/BotaoWhatsAppFlutuante.astro"

interface Props {
  title: string
  description: string
  canonical?: string
}

const { title, description, canonical } = Astro.props
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString()
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;500;600&family=Bebas+Neue&family=Rajdhani:wght@500;600;700&display=swap" rel="stylesheet" />

    <!-- Font Awesome (botão flutuante) -->
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.5.0/css/font-awesome.min.css" />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#141414" />

    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-5BTDS6RL');</script>
    <!-- End Google Tag Manager -->

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-GSGH9J70TX"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GSGH9J70TX');
    </script>
    <!-- End Google Analytics 4 -->
  </head>
  <body class="bg-[#0A0A0A] text-[#F5F5F5] font-body antialiased">

    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5BTDS6RL"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <slot />
    <BotaoWhatsAppFlutuante />

    <!-- Rastreamento GA4: scroll, cliques e categorias de página -->
    <script is:inline>
      (function() {
        function gtag(){ window.dataLayer.push(arguments); }

        // Categoria da página
        var path = window.location.pathname;
        var cat = 'home';
        if (path.indexOf('/lp/revisao') !== -1)      cat = 'lp_revisao';
        else if (path.indexOf('/lp/performance') !== -1) cat = 'lp_performance';
        else if (path.indexOf('/lp/lavagem') !== -1)  cat = 'lp_lavagem';
        else if (path.indexOf('/lp/importados') !== -1)  cat = 'lp_importados';

        // Pageview com categoria
        gtag('event', 'page_view', {
          page_category: cat,
          page_location: window.location.href,
          page_title: document.title
        });

        // Scroll depth 50% e 100%
        var scrollFired = {};
        window.addEventListener('scroll', function() {
          var scrollable = document.documentElement.scrollHeight - window.innerHeight;
          if (scrollable <= 0) return;
          var pct = Math.round((window.scrollY / scrollable) * 100);
          [50, 100].forEach(function(depth) {
            if (!scrollFired[depth] && pct >= depth) {
              scrollFired[depth] = true;
              var evtScroll = depth === 50 ? 'scroll_50' : 'scroll_100';
              gtag('event', evtScroll, { page_category: cat });
              window.dataLayer.push({ event: evtScroll, page_category: cat });
            }
          });
        }, { passive: true });

        // Cliques em links
        document.addEventListener('click', function(e) {
          var link = e.target.closest('a');
          if (!link || !link.href) return;
          var href = link.href;

          if (href.indexOf('wa.me') !== -1) {
            var evtName = link.classList.contains('whatsapp-float') ? 'btn_whatsapp_float' : 'btn_whatsapp';
            gtag('event', evtName, { page_category: cat });
            window.dataLayer.push({ event: evtName, page_category: cat });
          } else if (href.indexOf('instagram.com') !== -1) {
            gtag('event', 'click_instagram', { page_category: cat });
            window.dataLayer.push({ event: 'click_instagram', page_category: cat });
          } else if (href.indexOf('maps.google') !== -1 || href.indexOf('google.com/maps') !== -1) {
            gtag('event', 'click_rota_mapa', { page_category: cat });
            window.dataLayer.push({ event: 'click_rota_mapa', page_category: cat });
          } else if (href.indexOf('#servicos') !== -1) {
            gtag('event', 'click_ver_servicos', { page_category: cat });
            window.dataLayer.push({ event: 'click_ver_servicos', page_category: cat });
          }
        });
      })();
    </script>
  </body>
</html>
